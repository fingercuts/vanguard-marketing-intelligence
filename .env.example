# Marketing Analytics Data Platform - Environment Configuration
# Copy this file to .env and adjust values as needed

# Database
DUCKDB_PATH=db/marketing.duckdb

# Data Generation
DATA_START_DATE=2024-01-01
DATA_END_DATE=2026-04-07
NUM_CAMPAIGNS=10
CHANNELS=Google Ads,Facebook Ads,TikTok Ads

# Pipeline
PIPELINE_MODE=full
LOG_LEVEL=INFO

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_THEME=dark
